   "source": [
    "# Creating a Blank Image with Pillow\n",
    "\n",
    "from PIL import Image\n",
    "\n",
    "# Create a new RGB image\n",
    "width, height = 600, 400\n",
    "image = Image.new(\"RGB\", (width, height), \"white\")\n",
    "\n",
    "image.show()\n",
    "image.save(\"blank_image.png\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "5ef32742",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "os.startfile(\"blank_image.png\")"
   ]
  }
