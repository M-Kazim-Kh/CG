   "source": [
    "from PIL import Image\n",
    "\n",
    "image = Image.new(\"RGB\", (300, 300))\n",
    "\n",
    "for x in range(300):\n",
    "    for y in range(300):\n",
    "        image.putpixel((x, y), (x % 256, y % 256, 150))\n",
    "\n",
    "image.save(\"gradient.png\")\n",
    "image.show()"
   ]
  }
 ],
