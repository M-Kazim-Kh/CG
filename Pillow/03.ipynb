   "source": [
    "from PIL import Image, ImageDraw\n",
    "\n",
    "image = Image.new(\"RGB\", (300, 200), \"white\")\n",
    "draw = ImageDraw.Draw(image)\n",
    "\n",
    "draw.text((100, 90), \"Computer Graphics\", fill=\"black\")\n",
    "\n",
    "image.save(\"text_image.png\")\n",
    "image.show()"
   ]
  }
