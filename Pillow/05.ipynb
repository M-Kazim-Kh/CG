   "source": [
    "from PIL import Image, ImageFilter\n",
    "\n",
    "image = Image.open(\"Lion.webp\")\n",
    "\n",
    "blurred = image.filter(ImageFilter.BLUR)\n",
    "blurred.save(\"blurred_lion.png\")\n",
    "blurred.show()"
   ]
  }
