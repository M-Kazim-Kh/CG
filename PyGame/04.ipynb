   "source": [
    "from PIL import Image\n",
    "\n",
    "width, height = 300, 100\n",
    "image = Image.new(\"RGB\", (width, height))\n",
    "\n",
    "for x in range(width):\n",
    "    for y in range(height):\n",
    "        value = int((x / width) * 255)  # قيمة من 0 إلى 255\n",
    "        image.putpixel((x, y), (value, value, value))\n",
    "\n",
    "image.show()"
   ]
  }
 ],
